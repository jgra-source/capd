{
  "manifest_version": 3,
  "name": "Capd",
  "version": "1.0.2",
  "description": "Live Claude usage: session (5h) + weekly rate-limit utilization, reset countdowns, and credit balance \u2014 read straight from claude.ai.",
  "permissions": [
    "webRequest",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://*.anthropic.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Capd",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "inject.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}